<script>
/* ── CURSOR ──────────────────────────────────────────────── */
const dot = document.getElementById('cursor-dot');
const ring = document.getElementById('cursor-ring');
let mx = -100, my = -100, rx = -100, ry = -100;
document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
function animCursor() {
  dot.style.left = mx + 'px'; dot.style.top = my + 'px';
  rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
  ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
  requestAnimationFrame(animCursor);
}
animCursor();

/* ── PROGRESS BAR ────────────────────────────────────────── */
const progress = document.getElementById('progress');
window.addEventListener('scroll', () => {
  const s = document.documentElement.scrollTop;
  const h = document.documentElement.scrollHeight - window.innerHeight;
  progress.style.transform = `scaleX(${s / h})`;
});

/* ── HERO ENTRANCE ───────────────────────────────────────── */
window.addEventListener('load', () => {
  gsap.registerPlugin(ScrollTrigger);

  gsap.timeline({ delay: 0.3 })
    .to('#hero-eyebrow', { opacity: 1, duration: 0.8, ease: 'power3.out' })
    .from('.hero-title .line-1', { y: 60, opacity: 0, duration: 1, ease: 'power3.out' }, '-=0.4')
    .from('.hero-title .line-2', { y: 60, opacity: 0, duration: 1, ease: 'power3.out' }, '-=0.7')
    .to('#hero-desc', { opacity: 1, duration: 0.7, ease: 'power2.out' }, '-=0.3')
    .to('#hero-scroll', { opacity: 1, duration: 0.5 }, '-=0.2');

  /* ── SHIFT ITEMS ─────────────────────────────────────── */
  document.querySelectorAll('.shift-item').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 85%',
      onEnter: () => {
        setTimeout(() => el.classList.add('visible'), i * 80);
      }
    });
  });

  /* ── SIGNAL CARDS ────────────────────────────────────── */
  document.querySelectorAll('.signal-card').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 88%',
      onEnter: () => setTimeout(() => el.classList.add('visible'), i * 60)
    });
  });

  /* ── OPP ITEMS ───────────────────────────────────────── */
  document.querySelectorAll('.opp-item').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 88%',
      onEnter: () => setTimeout(() => el.classList.add('visible'), i * 100)
    });
  });

  /* ── SYSTEM CARDS ────────────────────────────────────── */
  document.querySelectorAll('.system-card').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 88%',
      onEnter: () => setTimeout(() => el.classList.add('visible'), i * 120)
    });
  });

  /* ── IDEA ROWS ───────────────────────────────────────── */
  document.querySelectorAll('.idea-row').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 90%',
      onEnter: () => setTimeout(() => el.classList.add('visible'), i * 70)
    });
  });

  /* ── DIR CARDS ───────────────────────────────────────── */
  document.querySelectorAll('.dir-card').forEach((el, i) => {
    ScrollTrigger.create({
      trigger: el, start: 'top 88%',
      onEnter: () => setTimeout(() => el.classList.add('visible'), i * 150)
    });
  });
});

/* ── TICKER ──────────────────────────────────────────────── */
const signals = [
  { text: 'Claude Mythos 5 · 10T paramètres · En test interne Anthropic', type: 'hot' },
  { text: 'OpenAI raise $122B · Valorisation $852B', type: 'hot' },
  { text: 'Gemma 4 31B · Apache 2.0 · Un seul GPU · #3 open model mondial', type: 'cold' },
  { text: 'Mastercard Agent Pay · IA achète de façon autonome via ChatGPT', type: '' },
  { text: 'GLM-5.1 · MIT license · Bat GPT-5.4 sur SWE-Bench Pro', type: 'cold' },
  { text: 'EU AI Act · Deadline AOÛT 2026 · Fines jusqu\'à €35M', type: 'hot' },
  { text: 'ECB: adoption IA employés 26%→40% en 2025 · Record historique', type: '' },
  { text: 'Salesforce Slack · 30 features IA · Restructuration workflows', type: '' },
  { text: 'Seed AI startups YC · Valorisation ~$40M dès le départ', type: 'hot' },
  { text: 'Apply AI Strategy EU · AI Continent Action Plan · Financement massif', type: 'cold' },
];
const track = document.getElementById('ticker');
const doubled = [...signals, ...signals];
doubled.forEach(s => {
  const div = document.createElement('div');
  div.className = `ticker-item ${s.type}`;
  div.innerHTML = `<div class="ticker-dot"></div><span>${s.text}</span>`;
  track.appendChild(div);
});

/* ── SIGNALS GRID ────────────────────────────────────────── */
const signalData = [
  { type: 'Modèle · Frontier', text: '<strong>Claude Mythos 5</strong> en test interne: 10T paramètres. Step-change de capacités. Potential Q2 2026. Anthropic prépare quelque chose de différent.', impact: 'high' },
  { type: 'Infrastructure · Finance', text: '<strong>OpenAI $122B raise</strong> à $852B de valorisation. Amazon, Nvidia, SoftBank. Signal de consolidation autour des labs américains. Le gap avec l\'Europe se creuse.', impact: 'high' },
  { type: 'Open Source · Edge', text: '<strong>Gemma 4 31B</strong> — Apache 2.0, GPU unique, #3 mondial. 85.2% MMLU Pro. Bat des modèles 20× plus grands. Ouvre la voie à des déploiements GDPR-natifs.', impact: 'medium' },
  { type: 'Commerce · Agentic', text: '<strong>Mastercard Agent Pay</strong>: les agents IA font des achats autonomes via ChatGPT. L\'agentic commerce devient réalité. Microsoft + OpenAI validé.', impact: 'medium' },
  { type: 'Open Source · Code', text: '<strong>GLM-5.1 MIT license</strong>: 744B params, 40B actifs (MoE). Bat Claude Opus 4.6 et GPT-5.4 sur SWE-Bench Pro. Open source gagne la course au coding.', impact: 'high' },
  { type: 'Régulation · EU', text: '<strong>EU AI Act août 2026</strong>: conformité obligatoire. Fines jusqu\'à €35M ou 7% CA mondial. 80% des entreprises ne sont pas prêtes. Fenêtre de consulting ouverte.', impact: 'high' },
  { type: 'Macro · Europe', text: '<strong>ECB Survey</strong>: adoption IA employés 26%→40% en 2025. Plus rapide qu\'internet ou les PC. PME investissent en moyenne 9% de leur capex dans l\'IA en 2026.', impact: 'medium' },
  { type: 'Enterprise · Produit', text: '<strong>Salesforce Slack + 30 features IA</strong>: automatisation emails, search augmentée, réponses auto. L\'IA s\'intègre dans l\'outil existant — not a new tool.', impact: 'low' },
];
const container = document.getElementById('signals-container');
signalData.forEach(s => {
  const card = document.createElement('div');
  card.className = 'signal-card';
  const impactLabel = s.impact === 'high' ? '↑ Impact élevé' : s.impact === 'medium' ? '→ Impact moyen' : '↓ Impact secondaire';
  card.innerHTML = `
    <div class="signal-card-type">${s.type}</div>
    <div class="signal-card-text">${s.text}</div>
    <div class="signal-impact ${s.impact}">${impactLabel}</div>
  `;
  container.appendChild(card);
});

/* ── SHIFTS INTRO CHARS ──────────────────────────────────── */
Splitting({ target: '#shifts-intro', by: 'words' });
</script>
</body>
</html>
