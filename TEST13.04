<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIGNAL — Veille IA · Semaine 7–13 Avril 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
<script src="https://unpkg.com/splitting/dist/splitting.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/splitting/dist/splitting.css">
<style>
/* ── TOKENS ─────────────────────────────────────────────── */
:root {
  --bg: #060608;
  --surface: #0d0d10;
  --surface-2: #13131a;
  --border: rgba(255,255,255,0.06);
  --text: #e8e6f0;
  --text-muted: #7a7889;
  --text-faint: #3a3848;
  --accent: #c8ff00;
  --accent-2: #ff4d6d;
  --accent-3: #00d4ff;
  --font-display: 'Space Mono', monospace;
  --font-body: 'Space Grotesk', sans-serif;
}

/* ── RESET ───────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  line-height: 1.6;
  overflow-x: hidden;
  cursor: none;
}
::selection { background: var(--accent); color: #000; }

/* ── CUSTOM CURSOR ───────────────────────────────────────── */
#cursor-dot {
  position: fixed; width: 8px; height: 8px;
  background: var(--accent); border-radius: 50%;
  pointer-events: none; z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform 0.05s, opacity 0.2s;
  mix-blend-mode: difference;
}
#cursor-ring {
  position: fixed; width: 32px; height: 32px;
  border: 1px solid rgba(200, 255, 0, 0.4);
  border-radius: 50%; pointer-events: none; z-index: 9998;
  transform: translate(-50%, -50%);
  transition: transform 0.12s cubic-bezier(0.16,1,0.3,1),
              width 0.3s, height 0.3s, opacity 0.2s;
}
body:has(a:hover) #cursor-ring,
body:has(button:hover) #cursor-ring { width: 56px; height: 56px; }

/* ── NOISE OVERLAY ───────────────────────────────────────── */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 9997;
}

/* ── PROGRESS BAR ────────────────────────────────────────── */
#progress {
  position: fixed; top: 0; left: 0; height: 2px;
  background: var(--accent); transform-origin: left;
  transform: scaleX(0); z-index: 1000; will-change: transform;
}

/* ── NAV ─────────────────────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.5rem 2.5rem;
  display: flex; align-items: center; justify-content: space-between;
  mix-blend-mode: normal;
}
.nav-logo {
  font-family: var(--font-display); font-size: 0.75rem;
  letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent);
  text-decoration: none;
}
.nav-meta {
  font-family: var(--font-display); font-size: 0.65rem;
  color: var(--text-muted); letter-spacing: 0.15em;
  text-transform: uppercase;
}
.nav-index {
  display: flex; gap: 1.5rem; list-style: none;
}
.nav-index a {
  font-family: var(--font-display); font-size: 0.65rem;
  color: var(--text-faint); text-decoration: none;
  letter-spacing: 0.15em; text-transform: uppercase;
  transition: color 0.2s;
}
.nav-index a:hover { color: var(--accent); }

/* ── HERO ────────────────────────────────────────────────── */
#hero {
  min-height: 100dvh;
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: clamp(2rem, 6vw, 5rem);
  position: relative; overflow: hidden;
}
.hero-bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(200,255,0,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,255,0,0.025) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridPulse 8s ease-in-out infinite alternate;
}
@keyframes gridPulse {
  from { opacity: 0.4; }
  to { opacity: 1; }
}
.hero-scan {
  position: absolute; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0.3; animation: scan 6s linear infinite;
}
@keyframes scan { from { top: 0; } to { top: 100%; } }

.hero-eyebrow {
  font-family: var(--font-display); font-size: clamp(0.6rem, 0.8vw, 0.75rem);
  color: var(--accent); letter-spacing: 0.4em;
  text-transform: uppercase; margin-bottom: 2rem;
  opacity: 0;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 12vw, 10rem);
  font-weight: 700; line-height: 0.88;
  color: var(--text); letter-spacing: -0.04em;
  margin-bottom: 3rem;
}
.hero-title .line-2 { color: var(--accent); }
.hero-bottom {
  display: flex; justify-content: space-between; align-items: flex-end;
  gap: 2rem;
}
.hero-descriptor {
  max-width: 380px;
  font-size: clamp(0.875rem, 1vw, 1rem);
  color: var(--text-muted); line-height: 1.5;
  opacity: 0;
}
.hero-scroll-cue {
  font-family: var(--font-display); font-size: 0.6rem;
  color: var(--text-faint); letter-spacing: 0.3em;
  text-transform: uppercase; writing-mode: vertical-rl;
  display: flex; align-items: center; gap: 0.75rem;
  opacity: 0;
}
.hero-scroll-cue::before {
  content: ''; width: 1px; height: 60px;
  background: linear-gradient(to bottom, var(--accent), transparent);
}

/* ── SECTION STRUCTURE ───────────────────────────────────── */
section {
  padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 5vw, 4rem);
  position: relative;
}
.section-label {
  font-family: var(--font-display); font-size: 0.65rem;
  letter-spacing: 0.35em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 3rem;
  display: flex; align-items: center; gap: 1rem;
}
.section-label::before {
  content: ''; flex: 0 0 40px; height: 1px;
  background: var(--accent);
}
.section-number {
  font-family: var(--font-display); font-size: 0.6rem;
  color: var(--text-faint); margin-right: 1rem;
}

/* ── SHIFTS SECTION ──────────────────────────────────────── */
#shifts {
  background: var(--bg);
  border-top: 1px solid var(--border);
}
.shifts-intro {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 3.5rem);
  line-height: 1.05; font-weight: 700;
  max-width: 800px; margin-bottom: 5rem;
  color: var(--text);
}
.shifts-intro em { color: var(--accent); font-style: normal; }

.shift-item {
  display: grid; grid-template-columns: 80px 1fr;
  gap: 0 3rem; padding: 2.5rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 0; transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
  cursor: default;
}
.shift-item.visible { opacity: 1; transform: none; }
.shift-item:hover .shift-title { color: var(--accent); }

.shift-num {
  font-family: var(--font-display); font-size: 0.6rem;
  color: var(--text-faint); padding-top: 0.4rem;
  letter-spacing: 0.1em; align-self: start;
}
.shift-body {}
.shift-title {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 2.2vw, 1.5rem);
  font-weight: 700; margin-bottom: 0.75rem;
  transition: color 0.2s; line-height: 1.2;
}
.shift-desc {
  color: var(--text-muted); font-size: 0.95rem;
  max-width: 600px; line-height: 1.55;
}
.shift-tag {
  display: inline-block; margin-top: 0.75rem;
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.25em; text-transform: uppercase;
  padding: 0.25rem 0.75rem;
  border: 1px solid var(--accent-3);
  color: var(--accent-3); border-radius: 999px;
}

/* ── SIGNALS TICKER ──────────────────────────────────────── */
#signals {
  overflow: hidden; padding-top: 0; padding-bottom: 0;
}
.ticker-wrap {
  padding: 1.5rem 0;
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.ticker-track {
  display: flex; gap: 0;
  animation: ticker 35s linear infinite;
  width: max-content;
}
.ticker-track:hover { animation-play-state: paused; }
@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.ticker-item {
  display: flex; align-items: center; gap: 1.5rem;
  padding: 0 3rem; white-space: nowrap;
  font-family: var(--font-display); font-size: 0.65rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--text-muted);
}
.ticker-dot {
  width: 4px; height: 4px; border-radius: 50%;
  background: var(--accent);
}
.ticker-item.hot .ticker-dot { background: var(--accent-2); }
.ticker-item.cold .ticker-dot { background: var(--accent-3); }

/* ── SIGNALS GRID ────────────────────────────────────────── */
#signals-grid {
  padding-top: 5rem;
}
.signals-title {
  font-family: var(--font-display);
  font-size: clamp(0.75rem, 1vw, 0.9rem);
  color: var(--accent); letter-spacing: 0.35em;
  text-transform: uppercase; margin-bottom: 3rem;
  display: flex; align-items: center; gap: 1rem;
}
.signals-title::before {
  content: ''; flex: 0 0 40px; height: 1px;
  background: var(--accent);
}
.signals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(320px, 100%), 1fr));
  gap: 1px; background: var(--border);
}
.signal-card {
  background: var(--bg);
  padding: 2rem;
  position: relative; overflow: hidden;
  opacity: 0;
}
.signal-card.visible { opacity: 1; }
.signal-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 1px; background: transparent;
  transition: background 0.3s;
}
.signal-card:hover::before { background: var(--accent); }
.signal-card:hover { background: var(--surface); }
.signal-card-type {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--text-faint); margin-bottom: 1rem;
}
.signal-card-text {
  font-size: 0.9rem; line-height: 1.5;
  color: var(--text-muted);
}
.signal-card-text strong { color: var(--text); }
.signal-impact {
  margin-top: 1rem;
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.2em; text-transform: uppercase;
}
.signal-impact.high { color: var(--accent-2); }
.signal-impact.medium { color: var(--accent); }
.signal-impact.low { color: var(--accent-3); }

/* ── OPPORTUNITIES ───────────────────────────────────────── */
#opportunities {
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.opp-header {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 4rem;
}
.opp-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 700; line-height: 1;
}
.opp-count {
  font-family: var(--font-display);
  font-size: clamp(4rem, 10vw, 8rem);
  color: var(--text-faint); line-height: 1;
  font-weight: 700; letter-spacing: -0.04em;
}

.opp-list { counter-reset: opp; }
.opp-item {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 1.5rem 3rem;
  padding: 2rem 0;
  border-bottom: 1px solid var(--border);
  position: relative;
  opacity: 0; transform: translateX(-20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.opp-item.visible { opacity: 1; transform: none; }
.opp-item-left {}
.opp-tag {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.3em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 0.5rem;
}
.opp-name {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 2.5vw, 1.7rem);
  font-weight: 700; color: var(--text);
  line-height: 1.1; margin-bottom: 0.75rem;
}
.opp-desc {
  font-size: 0.9rem; color: var(--text-muted);
  max-width: 560px; line-height: 1.55;
}
.opp-action {
  display: flex; flex-direction: column; align-items: flex-end;
  gap: 0.5rem;
}
.opp-horizon {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--text-faint);
}
.opp-priority {
  font-family: var(--font-display); font-size: 0.6rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  padding: 0.3rem 0.75rem;
  border-radius: 999px;
}
.opp-priority.critical {
  background: rgba(255, 77, 109, 0.1);
  color: var(--accent-2);
  border: 1px solid rgba(255,77,109,0.3);
}
.opp-priority.high {
  background: rgba(200, 255, 0, 0.08);
  color: var(--accent);
  border: 1px solid rgba(200,255,0,0.2);
}
.opp-priority.strategic {
  background: rgba(0, 212, 255, 0.08);
  color: var(--accent-3);
  border: 1px solid rgba(0,212,255,0.2);
}

/* ── SYSTEMS ─────────────────────────────────────────────── */
#systems {
  background: var(--bg);
  border-top: 1px solid var(--border);
}
.systems-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(360px, 100%), 1fr));
  gap: 2px; background: var(--border);
  margin-top: 3rem;
}
.system-card {
  background: var(--bg); padding: 2.5rem;
  position: relative; overflow: hidden;
  opacity: 0;
  transition: opacity 0.6s ease, background 0.3s;
}
.system-card.visible { opacity: 1; }
.system-card:hover { background: var(--surface); }
.system-card-accent {
  position: absolute; top: 0; right: 0;
  width: 1px; height: 60px;
  background: linear-gradient(to bottom, var(--accent), transparent);
  transition: height 0.4s cubic-bezier(0.16,1,0.3,1);
}
.system-card:hover .system-card-accent { height: 100%; opacity: 0.3; }
.system-icon {
  width: 40px; height: 40px; margin-bottom: 1.5rem;
  border: 1px solid var(--border); border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
}
.system-icon svg { width: 18px; height: 18px; stroke: var(--accent); fill: none; stroke-width: 1.5; }
.system-name {
  font-family: var(--font-display); font-weight: 700;
  font-size: 1.1rem; margin-bottom: 0.75rem;
  line-height: 1.2;
}
.system-desc {
  font-size: 0.875rem; color: var(--text-muted);
  line-height: 1.55; margin-bottom: 1.5rem;
}
.system-stack {
  display: flex; flex-wrap: wrap; gap: 0.4rem;
}
.stack-tag {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.2rem 0.6rem;
  background: var(--surface-2); color: var(--text-muted);
  border-radius: 3px;
}

/* ── CONTENT IDEAS ───────────────────────────────────────── */
#content {
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.content-heading {
  font-family: var(--font-display);
  font-size: clamp(0.6rem, 0.9vw, 0.75rem);
  letter-spacing: 0.4em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 4rem;
  display: flex; align-items: center; gap: 1rem;
}
.content-heading::before {
  content: ''; flex: 0 0 40px; height: 1px; background: var(--accent);
}
.content-ideas { display: flex; flex-direction: column; gap: 0; }
.idea-row {
  display: grid; grid-template-columns: 60px 1fr auto;
  align-items: baseline; gap: 2rem;
  padding: 1.75rem 0;
  border-bottom: 1px solid var(--border);
  opacity: 0; transform: translateY(10px);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.idea-row.visible { opacity: 1; transform: none; }
.idea-row:hover .idea-title { color: var(--accent); }
.idea-n {
  font-family: var(--font-display); font-size: 0.6rem;
  color: var(--text-faint); letter-spacing: 0.1em;
}
.idea-title {
  font-family: var(--font-display); font-weight: 700;
  font-size: clamp(0.9rem, 1.5vw, 1.15rem);
  color: var(--text); transition: color 0.2s;
  line-height: 1.25;
}
.idea-format {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--text-faint); white-space: nowrap;
}

/* ── DIRECTION FINALE ────────────────────────────────────── */
#direction {
  background: var(--bg);
  border-top: 1px solid var(--border);
  min-height: 70vh;
  display: flex; flex-direction: column; justify-content: center;
}
.direction-label {
  font-family: var(--font-display); font-size: 0.65rem;
  letter-spacing: 0.35em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 3rem;
  display: flex; align-items: center; gap: 1rem;
}
.direction-label::before {
  content: ''; flex: 0 0 40px; height: 1px; background: var(--accent);
}
.direction-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; background: var(--border); margin-top: 2rem;
}
.dir-card {
  background: var(--bg); padding: 2.5rem 2rem;
  opacity: 0;
  transition: opacity 0.5s ease, background 0.3s;
}
.dir-card.visible { opacity: 1; }
.dir-card:hover { background: var(--surface); }
.dir-card-label {
  font-family: var(--font-display); font-size: 0.55rem;
  letter-spacing: 0.3em; text-transform: uppercase;
  margin-bottom: 1.25rem; padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.dir-card-label.now { color: var(--accent-2); border-color: rgba(255,77,109,0.2); }
.dir-card-label.exploit { color: var(--accent); border-color: rgba(200,255,0,0.2); }
.dir-card-label.edge { color: var(--accent-3); border-color: rgba(0,212,255,0.2); }
.dir-card-content {
  font-size: 0.875rem; color: var(--text-muted);
  line-height: 1.6;
}
.dir-card-content strong { color: var(--text); display: block; margin-bottom: 0.4rem; }

/* ── FOOTER ──────────────────────────────────────────────── */
footer {
  padding: 2rem 2.5rem;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  gap: 1rem;
}
.footer-sig {
  font-family: var(--font-display); font-size: 0.6rem;
  color: var(--text-faint); letter-spacing: 0.2em;
}
.footer-sig strong { color: var(--text-muted); }

/* ── SCROLL DRIVEN LINES ─────────────────────────────────── */
.hline {
  height: 1px; background: var(--border);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
}
.hline.expanded { transform: scaleX(1); }

/* ── GLITCH ──────────────────────────────────────────────── */
.glitch {
  position: relative;
}
.glitch::before, .glitch::after {
  content: attr(data-text);
  position: absolute; top: 0; left: 0;
  font-family: inherit; font-size: inherit; font-weight: inherit;
  color: inherit;
}
.glitch::before {
  animation: glitch1 3.5s infinite linear;
  clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
  transform: translate(-2px, -1px);
  color: var(--accent-2); opacity: 0;
}
.glitch::after {
  animation: glitch2 4s infinite linear;
  clip-path: polygon(0 66%, 100% 66%, 100% 100%, 0 100%);
  transform: translate(2px, 1px);
  color: var(--accent-3); opacity: 0;
}
@keyframes glitch1 {
  0%, 92%, 100% { opacity: 0; }
  93%, 95% { opacity: 0.8; transform: translate(-3px, -1px); }
  94% { transform: translate(3px, 1px); }
}
@keyframes glitch2 {
  0%, 88%, 100% { opacity: 0; }
  89%, 91% { opacity: 0.6; transform: translate(3px, 0); }
  90% { transform: translate(-2px, 1px); }
}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media (max-width: 768px) {
  nav { padding: 1.25rem 1.5rem; }
  .nav-index { display: none; }
  .hero-title { font-size: clamp(3rem, 14vw, 5rem); }
  .shift-item { grid-template-columns: 40px 1fr; gap: 0 1.5rem; }
  .opp-item { grid-template-columns: 1fr; }
  .opp-action { align-items: flex-start; }
  .direction-grid { grid-template-columns: 1fr; }
  .idea-row { grid-template-columns: 40px 1fr; }
  .idea-format { display: none; }
  #cursor-dot, #cursor-ring { display: none; }
  body { cursor: auto; }
  .hero-bottom { flex-direction: column; }
}
</style>
</head>
<body>

<!-- CURSOR -->
<div id="cursor-dot"></div>
